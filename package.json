{
  "name": "gregoralbrecht.com",
  "description": "My personal website",
  "version": "0.0.1",
  "author": "Gregor Albrecht <hello@gregoralbrecht.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/gregoralbrecht/gregoralbrecht.com"
  },
  "bugs": {
    "url": "https://github.com/gregoralbrecht/gregoralbrecht.com/issues"
  },
  "keywords": [
    "react",
    "gatsby",
    "styled-components",
    "styled-system"
  ],
  "scripts": {
    "dev": "gatsby develop -o",
    "build": "gatsby build",
    "clean": "gatsby clean",
    "format": "prettier --write \"src/**/*.{jsx,js}\"",
    "lint": "yarn lint:scripts && yarn lint:styles",
    "lint:scripts": "eslint './src/**/*.{jsx,js}'",
    "lint:styles": "stylelint './src/**/*.{jsx,js}'",
    "deduplicate": "yarn-deduplicate -s fewer yarn.lock",
    "deduplicate:check": "yarn-deduplicate -s fewer yarn.lock --list --fail"
  },
  "husky": {
    "hooks": {
      "pre-commit": "pretty-quick --staged"
    }
  },
  "dependencies": {
    "gatsby": "^2.31.0-next.0",
    "gatsby-image": "^2.2.40",
    "gatsby-plugin-image": "^0.6.0-next.0",
    "gatsby-plugin-sharp": "^2.13.0-next.0",
    "gatsby-source-filesystem": "^2.3.0",
    "gatsby-transformer-sharp": "^2.11.0-next.0",
    "prop-types": "^15.7.2",
    "react": "17.0.1",
    "react-dom": "17.0.1",
    "typeface-work-sans": "^1.1.13"
  },
  "devDependencies": {
    "@babel/core": "^7.9.0",
    "@gregoralbrecht/eslint-config": "^1.1.2",
    "babel-preset-gatsby": "^0.9.1",
    "eslint": "^7.4.0",
    "husky": "^4.3.6",
    "prettier": "^2.0.5",
    "pretty-quick": "^3.1.0",
    "stylelint": "11.1.1",
    "stylelint-config-recommended": "^3.0.0",
    "stylelint-config-standard": "^20.0.0",
    "stylelint-config-styled-components": "^0.1.1",
    "stylelint-processor-styled-components": "^1.10.0",
    "yarn-deduplicate": "^3.1.0"
  }
}
